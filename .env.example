## Example .env for connecting to Supabase (Postgres)
# Replace the values with the connection string from your Supabase project
# You can find it in Supabase project Settings -> Database -> Connection string

# Example:
# DATABASE_URL=postgresql://postgres:yourpassword@db.abcd1234.supabase.co:5432/postgres
# If the provider requires SSL (Supabase does), enable DB_SSL=true

DATABASE_URL=
DATABASE_URL_POOLER=
DB_SSL=true
AUTO_CREATE_TABLES=false

# Optional: export in PowerShell before running the server:
# $Env:DATABASE_URL = 'postgresql://...'
# If your network cannot reach the direct db.* host, paste the Supabase pooler
# connection string into DATABASE_URL_POOLER instead.
# $Env:DB_SSL = 'true'
